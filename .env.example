# Copy to .env.local for local dev. Set the same vars in Vercel:
# https://vercel.com/docs/environment-variables
# Full setup walkthrough with direct links: docs/SETUP.md

# --- AI (OpenRouter) — create key: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# Model list: https://openrouter.ai/models (default below if unset)
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- Cron auth — any long random string (e.g. `openssl rand -hex 32`)
# Vercel sends it automatically once set: https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=

# --- Google APIs (self-improvement agent data sources)
# Service account: https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable APIs: https://console.cloud.google.com/apis/library/analyticsdata.googleapis.com
#              https://console.cloud.google.com/apis/library/searchconsole.googleapis.com
# Paste the downloaded JSON key as ONE line:
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# GA4 property id (number): https://analytics.google.com → Admin → Property settings
GA4_PROPERTY_ID=
# e.g. sc-domain:arranto.com  — https://search.google.com/search-console
SEARCH_CONSOLE_SITE_URL=

# --- Client analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=   # G-XXXXXXX  https://analytics.google.com
NEXT_PUBLIC_GTM_ID=              # GTM-XXXXXX https://tagmanager.google.com
NEXT_PUBLIC_GSC_VERIFICATION=    # Search Console HTML-tag token (content= value)

# --- Optional: email notification for new inquiries — https://web3forms.com
WEB3FORMS_KEY=

SITE_URL=https://arranto.com
